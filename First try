            updateElement('[data-i18n="whySubtitle"]', trans.whySubtitle);
            updateElement('[data-i18n="benefit1Title"]', trans.benefit1Title);
            updateElement('[data-i18n="benefit1Text"]', trans.benefit1Text);
            updateElement('[data-i18n="benefit2Title"]', trans.benefit2Title);
            updateElement('[data-i18n="benefit2Text"]', trans.benefit2Text);
