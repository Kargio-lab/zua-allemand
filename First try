        function switchLanguage(lang) {
            const html = document.documentElement;
            const body = document.body;
            
            // Update HTML lang and dir attributes
            html.setAttribute('lang', lang);
            if (lang === 'ar') {
                html.setAttribute('dir', 'rtl');
                body.style.fontFamily = "'Inter', 'Arial', sans-serif";
            } else {
                html.setAttribute('dir', 'ltr');
                body.style.fontFamily = "'Inter', sans-serif";
            }
            
            // Update active button state
            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.remove('active', 'bg-edu-blue-600', 'text-white');
                btn.classList.add('text-gray-600', 'hover:text-edu-blue-600');
            });
            const activeBtn = document.querySelector(`.lang-btn-${lang}`);
            activeBtn.classList.add('active', 'bg-edu-blue-600', 'text-white');
            activeBtn.classList.remove('text-gray-600', 'hover:text-edu-blue-600');
            
            // Update navigation links
            document.querySelectorAll('.nav-links a').forEach(link => {
                if (link.dataset[lang]) {
                    link.textContent = link.dataset[lang];
                }
            });
            
            // Update CTA button in nav
            const ctaBtn = document.querySelector('.cta-btn');
            if (ctaBtn && ctaBtn.dataset[lang]) {
                ctaBtn.textContent = ctaBtn.dataset[lang];
            }
            
            // Update all translatable elements
            const trans = translations[lang];
            
            // Hero section
            updateElement('[data-i18n="heroTag"]', trans.heroTag);
            updateElement('[data-i18n="heroTitle"]', trans.heroTitle, true);
            updateElement('[data-i18n="heroSubtitle"]', trans.heroSubtitle);
            updateElement('[data-i18n="heroSubtitleSecondary"]', trans.heroSubtitleSecondary);
            updateElement('[data-i18n="heroCTA1"]', trans.heroCTA1);
            updateElement('[data-i18n="heroCTA2"]', trans.heroCTA2);
            
            // Why German section
