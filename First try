    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        
        /* Custom Moroccan-inspired geometric pattern */
        .moroccan-pattern {
            background-image: 
                linear-gradient(45deg, rgba(0, 119, 182, 0.03) 25%, transparent 25%),
                linear-gradient(-45deg, rgba(0, 119, 182, 0.03) 25%, transparent 25%),
                linear-gradient(45deg, transparent 75%, rgba(0, 119, 182, 0.03) 75%),
                linear-gradient(-45deg, transparent 75%, rgba(0, 119, 182, 0.03) 75%);
            background-size: 20px 20px;
            background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
        }
        
        /* Smooth scroll offset for fixed header */
        html {
            scroll-padding-top: 80px;
        }
        
        /* Gradient text */
        .gradient-text {
            background: linear-gradient(135deg, #0077b6 0%, #00b4d8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        /* Custom animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .fade-in-up {
            animation: fadeInUp 0.6s ease-out forwards;
        }
        
        /* CTA pulse animation */
        @keyframes pulse-subtle {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(0, 119, 182, 0.4);
            }
            50% {
                box-shadow: 0 0 0 10px rgba(0, 119, 182, 0);
            }
        }
        
        .cta-pulse {
            animation: pulse-subtle 2s infinite;
        }
        
        /* Level card hover effect */
        .level-card {
            transition: all 0.3s ease;
        }
        
        .level-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 119, 182, 0.15);
        }
        
        /* Mobile optimization */
        @media (max-width: 640px) {
            .hero-title {
                font-size: 1.875rem;
                line-height: 2.25rem;
            }
        }
        
        /* Moroccan accent colors */
        .accent-morocco-red {
            color: #C1272D;
        }
        
        .accent-morocco-green {
            color: #006233;
        }
        
        .bg-morocco-teal {
            background-color: #008B8B;
        }
        
        /* Form focus states */
        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #0077b6;
            box-shadow: 0 0 0 3px rgba(0, 119, 182, 0.1);
        }
        
        /* Success message */
        .success-message {
            display: none;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .success-message.show {
            display: block;
            opacity: 1;
        }
        
        /* RTL Support for Arabic */
        [dir="rtl"] {
            text-align: right;
        }
        
        [dir="rtl"] .flex {
            flex-direction: row-reverse;
        }
        
        [dir="rtl"] .space-x-8 > * + * {
            margin-right: 2rem;
            margin-left: 0;
        }
        
        [dir="rtl"] .grid {
            direction: rtl;
        }
        
        /* Language switcher active state */
        .lang-btn.active {
            background-color: #0077b6;
            color: white;
        }
        
        /* Hide elements by language */
        [lang="de"] .lang-fr, [lang="de"] .lang-ar { display: none; }
        [lang="fr"] .lang-de, [lang="fr"] .lang-ar { display: none; }
        [lang="ar"] .lang-de, [lang="ar"] .lang-fr { display: none; }
    </style>
    
